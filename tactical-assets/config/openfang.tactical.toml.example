# ─────────────────────────────────────────────
# Operational Restrictions
# ─────────────────────────────────────────────
# [operational_restrictions]
# weapon_release_authority = "WeaponsTight"   # Hold | Tight | Free
#
# [[operational_restrictions.geofences]]
# name = "patrol_zone"
# boundary = [[30.0, 120.0], [30.5, 120.0], [30.5, 120.5], [30.0, 120.5]]
# restriction = "KeepIn"
# violation_action = "AutoCorrect"
#
# [[operational_restrictions.geofences]]
# name = "no_go_zone"
# boundary = [[31.0, 121.0], [31.2, 121.0], [31.2, 121.2], [31.0, 121.2]]
# restriction = "KeepOut"
# violation_action = "AbortMission"

# ─────────────────────────────────────────────
# Weapon Approval — quorum-based
# ─────────────────────────────────────────────
[approval]
require_approval = ["weapon_arm", "weapon_launch", "self_destruct"]
timeout_secs = 300                          # 5 min for weapon decisions
auto_approve_autonomous = false             # Default: require shore approval

# ─────────────────────────────────────────────
# Communication Monitor
# ─────────────────────────────────────────────
# [comm_monitor]
# ping_interval_secs = 30
# failure_threshold = 5                      # 5 consecutive failures → LinkLost
# peer_ids = ["shore_command", "hec"]

# ─────────────────────────────────────────────
# OFP P2P Network
# ─────────────────────────────────────────────
[network]
listen_addr = "0.0.0.0:4200"
shared_secret = ""                          # Required: set HMAC shared secret

# ─────────────────────────────────────────────
# Mission Config
# ─────────────────────────────────────────────
# [[mission_configs]]
# mission_id = "patrol_alpha"
# roe = { weapon_release_authority = "WeaponsTight" }
# geofences = ["patrol_zone", "no_go_zone"]
#
# [[mission_configs.contingency_plans]]
# name = "comms_lost"
# trigger = "CommLost"
# actions = [
#     { type = "SwitchAutonomyMode", mode = "L5_FullyAutonomous" },
#     { type = "DCC_RuleEnable", rule = "auto_rtb_on_low_fuel" },
# ]

# ─────────────────────────────────────────────
# Memory / Persistence
# ─────────────────────────────────────────────
[memory]
decay_rate = 0.05
sqlite_path = "~/.openfang/data/openfang.db"

# ─────────────────────────────────────────────
# API Server — local debug only
# ─────────────────────────────────────────────
# api_listen = "127.0.0.1:4201"
